  "symbol": "TICKER@MIC",
  "timeframe": "TIME_FRAME_M1",
  "bars_lookback_minutes": 60,
  "interval_seconds": 30,
  "max_iterations": 1,
  "streams": {
    "health": "broker.health",
    "readiness": "broker.readiness",
    "portfolio": "broker.portfolio.snapshot",
    "orders_snapshot": "broker.orders.snapshot",
    "market_data": "broker.market_data",
    "command_ack": "broker.command_acks",
    "runtime_bridge_dlq": "broker.runtime_bridge.dlq"
  },
  "retention": {
    "health_maxlen": 1000,
    "readiness_maxlen": 1000,
    "portfolio_maxlen": 1000,
    "order_snapshot_maxlen": 1000,
    "market_data_maxlen": 10000,
    "command_ack_maxlen": 1000,
    "runtime_bridge_dlq_maxlen": 1000
  },
  "broker_truth": {
    "cancel_reconciliation": {
      "precedence_version": "m3b8-example-v1",
      "freshness": {
