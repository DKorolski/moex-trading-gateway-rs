# Copy this file to `.env` and fill local values there.
# `.env` is git-ignored; `.env.example` must not contain real secrets/accounts.

# FINAM Trade API secret token generated in the FINAM token portal.
# Important: this is the secret value shown when the token is created,
# not the token name, token id, trading code, or account number.
# Never paste the real secret into chat or commit it to git.
FINAM_SECRET_TOKEN=

# Optional read-only probe inputs.
#
# Try the numeric account id first, for example the id from the FINAM account URL.
# If FINAM rejects it during read-only characterization, try broker account number
# or trading code only in local `.env`, not in this example file.
FINAM_ACCOUNT_ID=

# Optional FINAM instrument symbol for asset/bars probes.
# Keep empty until exact FINAM/MOEX symbol format is confirmed through assets.
# Example placeholder only:
# FINAM_SYMBOL=IMOEXF@RTSX
FINAM_SYMBOL=

# Example safe local commands after `.env` is filled:
#
# set -a; source .env; set +a
# cargo run -p broker-cli -- finam-auth-check
# cargo run -p broker-cli -- finam-readonly-check \
#   --account-id "$FINAM_ACCOUNT_ID" \
#   --limit 10 \
#   --output tmp/finam-readonly-redacted.json
